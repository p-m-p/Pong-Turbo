{
  "name": "pong-turbo",
  "version": "1.0.0",
  "description": "Pong Turbo — a canvas-based pong game with a Pac-Man twist",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "worker:dev": "wrangler dev --config worker/wrangler.toml --port 8787",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml",
    "worker:db:init": "wrangler d1 execute DB --local --config worker/wrangler.toml --file=worker/schema.sql",
    "worker:db:migrate": "wrangler d1 execute DB --remote --config worker/wrangler.toml --file=worker/schema.sql"
  },
  "keywords": [],
  "author": "",
  "type": "module",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "^17.4.0",
    "prettier": "3.8.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "wrangler": "^4.76.0"
  }
}
