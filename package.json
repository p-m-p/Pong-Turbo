{
  "name": "pong-turbo",
  "version": "1.0.0",
  "description": "Pong Turbo — a canvas-based pong game with a Pac-Man twist",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "worker:dev": "wrangler dev --config worker/wrangler.toml --port 8787",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml",
    "worker:db:init": "wrangler d1 execute DB --local --config worker/wrangler.toml --file=worker/schema.sql",
    "worker:db:migrate": "wrangler d1 execute DB --config worker/wrangler.toml --file=worker/schema.sql"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "wrangler": "^4.76.0"
  }
}
